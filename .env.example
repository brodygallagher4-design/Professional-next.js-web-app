# SimBazaar environment variables — copy to .env.local and fill with real values.
# NEVER commit real secrets. On Railway, set these in the project's Variables tab.

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase SERVICE ROLE key — server-only, full access. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key
