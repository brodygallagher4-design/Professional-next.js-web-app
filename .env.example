# SimBazaar environment variables — copy to .env.local and fill with real values.
# NEVER commit real secrets. On Railway, set these in the project's Variables tab.

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase SERVICE ROLE key — server-only, full access. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key

# ── Korapay payments (wallet deposits) ────────────────────────────────────────
# From your Korapay dashboard → Settings → API Keys. Server-only — never expose.
KORAPAY_SECRET_KEY=sk_live_or_test_xxx
KORAPAY_PUBLIC_KEY=pk_live_or_test_xxx
KORAPAY_ENCRYPTION_KEY=your-encryption-key
# Webhook URL configured in your Korapay dashboard (defaults to this if unset).
KORAPAY_WEBHOOK_URL=https://api.socialpannel.com/api/webhooks/korapay
# Public base URL of the app (used for the post-payment redirect). Optional —
# falls back to the request host.
APP_URL=https://api.socialpannel.com
